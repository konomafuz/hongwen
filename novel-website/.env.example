# Novel Website Environment Variables
# Copy this file to .env and fill in your values

# Secret key for JWT token signing
SECRET_KEY=your-secret-key-change-in-production

# Database
DATABASE_URL=postgresql+asyncpg://noveluser:novelpass@localhost:5432/noveldb

# Redis
REDIS_URL=redis://localhost:6379/0

# AI Provider 选择: deepseek | volcengine | openai | custom
AI_PROVIDER=deepseek

# DeepSeek API
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 火山引擎豆包 (Doubao) — OpenAI 兼容协议
# 模型字段填推理接入点 endpoint ID，如 "ep-2025xxxx-xxxxx"
# VOLCENGINE_API_KEY=your-volcengine-api-key
# VOLCENGINE_API_BASE=https://ark.cn-beijing.volces.com/api/v3
# VOLCENGINE_MODEL=ep-2025xxxx-xxxxx

# OpenAI 兼容 API (通用)
# OPENAI_API_KEY=
# OPENAI_API_BASE=
# OPENAI_MODEL=gpt-4

# Server
HOST=0.0.0.0
PORT=8000

# CORS
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:5173

# Logging
LOG_LEVEL=INFO